---
import '~/assets/styles/tailwind.css';
import { I18N } from 'astrowind:config';
import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Importamos el componente de Iconos para el botón flotante
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';
import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <!-- BOTÓN FLOTANTE DE CARRITO (WHATSAPP) -->
    <div class="fixed bottom-6 right-6 z-[999]">
      <button 
        onclick="enviarPedidoWhatsApp()"
        class="group flex items-center gap-3 bg-[#3D2B1F] text-[#F2E8DF] p-4 rounded-full shadow-2xl hover:bg-[#B57E5F] transition-all duration-300 transform hover:scale-110"
        aria-label="Enviar pedido por WhatsApp"
      >
        <div class="relative">
          <Icon name="tabler:shopping-bag" class="w-7 h-7" />
          <span 
            id="cart-count" 
            class="absolute -top-2 -right-2 bg-[#B57E5F] text-white text-[11px] font-bold w-5 h-5 flex items-center justify-center rounded-full border-2 border-[#3D2B1F] group-hover:border-[#B57E5F]"
          >
            0
          </span>
        </div>
        <span class="max-w-0 overflow-hidden whitespace-nowrap group-hover:max-w-xs transition-all duration-500 ease-in-out font-bold uppercase tracking-widest text-sm">
          Enviar Pedido
        </span>
      </button>
    </div>

    <BasicScripts />

    <!-- LÓGICA DEL CARRITO RITOHOUSE -->
    <script is:inline>
      // 1. Inicialización
      let carrito = JSON.parse(localStorage.getItem('ritohouse_cart')) || [];
      
      // Función para actualizar el número visual
      function actualizarContador() {
        const contador = document.getElementById('cart-count');
        if (contador) contador.innerText = carrito.length;
      }

      // Ejecutar al cargar la página
      actualizarContador();

      // 2. Función Global para agregar productos (Se llama desde las tiendas)
      window.agregarAlCarrito = (nombre, precio) => {
        carrito.push({ nombre, precio });
        localStorage.setItem('ritohouse_cart', JSON.stringify(carrito));
        actualizarContador();
        
        // Efecto visual simple
        console.log(`Añadido: ${nombre}`);
      };

      // 3. Función para enviar a tu WhatsApp 099556772
      window.enviarPedidoWhatsApp = () => {
        if (carrito.length === 0) {
          alert("Tu bolsa de rituales está vacía. Añade algunos elementos para continuar.");
          return;
        }

        let mensaje = "¡Hola RitoHouse! ✨ Me gustaría intencionar mi hogar con los siguientes artículos:%0A%0A";
        let total = 0;

        carrito.forEach((item, index) => {
          mensaje += `${index + 1}. *${item.nombre}* - $${item.precio}%0A`;
          total += parseInt(item.precio);
        });

        mensaje += `%0A*Total estimado: $${total}*%0A%0A¿Me podrían confirmar disponibilidad y formas de pago? 🙏`;
        
        // Tu número con formato internacional
        const whatsappUrl = `https://wa.me/59899556772?text=${mensaje}`;
        window.open(whatsappUrl, '_blank');
      };
    </script>
  </body>
</html>
