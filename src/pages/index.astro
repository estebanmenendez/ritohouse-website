---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { Icon } from 'astro-icon/components';

// Mantenemos los nombres de archivo originales para evitar el error de build
import img1 from '~/assets/images/img1.png';
import img2 from '~/assets/images/img2.png';

const metadata = {
  title: 'Ritohouse — Rituales que transforman hogares',
  ignoreTitleTemplate: true,
};

const footerData = {
  secondaryLinks: [
    { text: 'Diseñado por Steb · Ritohouse © 2026', href: '#' },
  ],
};
---

<Layout metadata={metadata} footerData={footerData}>

  <!-- SECCIÓN HERO -->
  <section class="relative h-screen flex items-center justify-center bg-[#EAE5DE] overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={img1.src} alt="Ritual Ritohouse" class="w-full h-full object-cover opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#EAE5DE]/20 via-transparent to-[#EAE5DE]"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-serif font-bold text-[#5C544E] mb-6 uppercase tracking-tight" style="text-shadow: 1px 1px 2px rgba(255,255,255,0.5);">
        RITOHOUSE <br /> <span class="text-[#D4A373] text-4xl md:text-5xl">Rituales con Intención</span>
      </h1>
      <p class="text-xl md:text-2xl text-[#5C544E] mb-10 font-light italic">
        Piezas artesanales en yeso y cemento diseñadas para armonizar tu hogar.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#productos" class="bg-[#5C544E] text-white font-semibold py-4 px-10 rounded-full no-underline tracking-widest hover:bg-[#D4A373] transition-colors shadow-lg">Ver los Boxes</a>
        <a href="#historia" class="text-[#5C544E] font-semibold py-4 px-10 no-underline hover:text-[#D4A373]">Nuestra Filosofía ↓</a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN HISTORIA -->
  <Content
    id="historia"
    isReversed
    tagline="Artesanía con Propósito"
    title="La Magia de lo Hecho a Mano"
    items={[
      {
        title: 'Piezas en Yeso y Cemento',
        description: 'Cada figura y bandeja es vertida a mano, cuidando la textura y la pureza del material para crear objetos únicos.',
        icon: 'tabler:artboard', 
      },
      {
        title: 'Velas y Aromas',
        description: 'Velas aromáticas e inciensos seleccionados para limpiar ambientes y preparar el espacio para tu ritual personal.',
        icon: 'tabler:flame',
      },
      {
        title: 'Intención y Decretos',
        description: 'Nuestros boxes incluyen tarjetas con decretos asociados a las piezas en yeso para que los usuarios les den su propia intención.',
        icon: 'tabler:feather',
      },
    ]}
    image={{
      src: img2,
      alt: 'Detalle de un box de ritual Ritohouse',
    }}
  >
    <Fragment slot="content">
      <div class="text-[#5C544E]">
        <p class="mb-4">
          <strong>Ritohouse</strong> nace de la unión de la creatividad y la espiritualidad en el hogar. Junto a mi señora, creamos <strong>boxes de ritual</strong> que incluyen artículos en yeso, velas, inciensos y palo santo.
        </p>
        <p class="mb-4">
          Cada box está acompañado de tarjetas y decretos que los usuarios deben leer para darle la intención al producto y que esta se manifieste en sus vidas.
        </p>
        <p>
          Ubicados en el litoral uruguayo, cada entrega es un pedazo de nuestra dedicación artesanal, empaquetado con materiales naturales.
        </p>
      </div>
    </Fragment>
  </Content>

  <!-- SECCIÓN CATEGORÍAS -->
  <Features
    id="productos"
    tagline="Nuestra Colección"
    title="Elementos para tu Ritual"
    items={[
      { title: 'Boxes Completos', description: 'Kits listos con todo lo necesario para intencionar.', icon: 'tabler:package' },
      { title: 'Piezas en Yeso', description: 'Portaveleras, bandejas y figuras decorativas artesanalmente producidas.', icon: 'tabler:flower' },
      { title: 'Aromaterapia', description: 'Inciensos, palo santo y velas con aromas naturales.', icon: 'tabler:wind' },
      { title: 'Jabones Artesanales', description: 'Limpieza física y energética con ingredientes naturales.', icon: 'tabler:droplet' },
      { title: 'Decretos', description: 'Tarjetas con afirmaciones para cada tipo de box y ritual.', icon: 'tabler:notes' },
      { title: 'Adornos Rústicos', description: 'Detalles en cemento y madera para espacios únicos.', icon: 'tabler:home-heart' },
    ]}
  />

  <!-- SECCIÓN CONTACTO -->
  <section id="contacto" class="relative py-16 bg-[#EAE5DE] border-t border-[#D4A373]/20">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#5C544E] uppercase tracking-widest mb-4">¡Conectemos!</h2>
        <p class="text-[#5C544E]/80 text-lg mb-8">
          ¿Tienes dudas sobre cómo realizar tu ritual o quieres un box personalizado? Escríbenos y te asesoraremos.
        </p>
        <div class="space-y-6">
          <div class="flex items-start">
            <Icon name="tabler:brand-instagram" class="w-6 h-6 text-[#D4A373] mr-4" />
            <div>
              <h4 class="text-[#5C544E] font-bold">Instagram</h4>
              <p class="text-[#5C544E]/70">@ritohousepdu</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white/50 p-8 rounded-2xl border border-[#D4A373]/20 shadow-sm">
        <form action="https://formspree.io/f/tu-id" method="POST" class="space-y-4">
          <input type="text" name="name" placeholder="Tu nombre" required class="w-full bg-[#EAE5DE]/30 border border-[#D4A373]/30 rounded-lg px-4 py-3" />
          <input type="email" name="email" placeholder="Tu email" required class="w-full bg-[#EAE5DE]/30 border border-[#D4A373]/30 rounded-lg px-4 py-3" />
          <textarea name="message" placeholder="¿En qué ritual estás pensando?" rows="4" required class="w-full bg-[#EAE5DE]/30 border border-[#D4A373]/30 rounded-lg px-4 py-3"></textarea>
          <button type="submit" class="w-full bg-[#D4A373] text-white font-bold py-3 rounded-lg uppercase tracking-widest hover:bg-[#5C544E] transition-all">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>
