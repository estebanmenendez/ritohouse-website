---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Tienda de Rituales — RitoHouse',
};

const productos = [
  // 1. ESENCIALES (Iniciación y limpieza básica)
  {
    id: 'e1',
    categoria: 'esenciales',
    nombre: 'Box Inicio Sagrado',
    descripcion: 'Lo fundamental para tu primer ritual de limpieza energética.',
    precio: '850',
  },
  {
    id: 'e2',
    categoria: 'esenciales',
    nombre: 'Box Purificación',
    descripcion: 'Ideal para limpiar nuevos espacios y renovar el aire del hogar.',
    precio: '920',
  },
  {
    id: 'e3',
    categoria: 'esenciales',
    nombre: 'Box Calma Interior',
    descripcion: 'Enfocado en la relajación diaria y el descenso del estrés.',
    precio: '880',
  },
  {
    id: 'e4',
    categoria: 'esenciales',
    nombre: 'Box Intención Lunar',
    descripcion: 'Set básico para conectar con las fases de la luna.',
    precio: '950',
  },

  // 2. EXPANSIÓN (Profundización y conexión)
  {
    id: 'ex1',
    categoria: 'expansion',
    nombre: 'Box Expansión Áurea',
    descripcion: 'Conexión profunda con elementos de la naturaleza y decretos.',
    precio: '1450',
  },
  {
    id: 'ex2',
    categoria: 'expansion',
    nombre: 'Box Abundancia Flor',
    descripcion: 'Atrae la prosperidad con botánica seca y cristales seleccionados.',
    precio: '1600',
  },
  {
    id: 'ex3',
    categoria: 'expansion',
    nombre: 'Box Protección Hogar',
    descripcion: 'Crea un escudo energético en las entradas de tu casa.',
    precio: '1550',
  },
  {
    id: 'ex4',
    categoria: 'expansion',
    nombre: 'Box Armonía Familiar',
    descripcion: 'Ritual diseñado para equilibrar la convivencia en espacios comunes.',
    precio: '1680',
  },

  // 3. TRASCENDENCIA (Maestría y Alquimia)
  {
    id: 't1',
    categoria: 'trascendencia',
    nombre: 'Box Trascendencia Total',
    descripcion: 'La experiencia de alquimia definitiva con piezas de diseño.',
    precio: '2800',
  },
  {
    id: 't2',
    categoria: 'trascendencia',
    nombre: 'Box Alquimia Ancestral',
    descripcion: 'Kit profesional con elementos de sahumado antiguo y resinas.',
    precio: '3100',
  },
  {
    id: 't3',
    categoria: 'trascendencia',
    nombre: 'Box Ritual de Vida',
    descripcion: 'Un viaje completo por los 4 elementos para momentos de cambio.',
    precio: '2950',
  },
  {
    id: 't4',
    categoria: 'trascendencia',
    nombre: 'Box Maestro de Luz',
    descripcion: 'Set premium con nuestras piezas de cemento más exclusivas.',
    precio: '3400',
  }
];
---

<Layout metadata={metadata}>
  <section class="bg-[#F2E8DF] min-h-screen py-20 text-[#3D2B1F]">
    <div class="max-w-7xl mx-auto px-4">
      
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif font-bold mb-4 uppercase tracking-tighter">Catálogo de Rituales</h1>
        <p class="italic text-[#55463C] text-lg">Selecciona tu intención y arma tu pedido personalizado</p>
        
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <a href="#esenciales" class="px-6 py-2 rounded-full border border-[#B57E5F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">ESENCIALES</a>
          <a href="#expansion" class="px-6 py-2 rounded-full border border-[#B57E5F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">EXPANSIÓN</a>
          <a href="#trascendencia" class="px-6 py-2 rounded-full border border-[#B57E5F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">TRASCENDENCIA</a>
        </div>
      </div>

      {/* RENDERIZADO DE CATEGORÍAS */}
      {['esenciales', 'expansion', 'trascendencia'].map((cat, index) => (
        <div id={cat} class="mb-24 scroll-mt-24">
          <h2 class="text-3xl font-serif font-bold text-[#B57E5F] border-b border-[#B57E5F]/20 pb-2 mb-10 uppercase tracking-widest text-center md:text-left">
            {index + 1}. Rituales de {cat.charAt(0).toUpperCase() + cat.slice(1)}
          </h2>
          
          <div class="grid md:grid-cols-4 gap-6">
            {productos.filter(p => p.categoria === cat).map(p => (
              /* CORRECCIÓN: Se añadió 'text-center' e 'items-center' para centrar todo el contenido */
              <div class="bg-white/30 rounded-2xl border border-[#B57E5F]/10 p-5 flex flex-col items-center text-center group hover:shadow-xl transition-all">
                <div class="aspect-video w-full bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30 overflow-hidden">
                  <span class="group-hover:scale-110 transition-transform duration-500 text-sm">Foto {p.nombre}</span>
                </div>
                <h3 class="text-lg font-bold mb-2 leading-tight text-[#3D2B1F]">{p.nombre}</h3>
                <p class="text-xs text-[#55463C] mb-4 flex-grow italic">{p.descripcion}</p>
                <div class="mb-5">
                  <span class="text-xl font-serif font-bold text-[#3D2B1F]">${p.precio}</span>
                </div>
                <button 
                  onclick={`agregarAlCarrito('${p.nombre}', '${p.precio}')`}
                  class="w-full bg-[#3D2B1F] text-[#F2E8DF] py-3 rounded-xl font-bold hover:bg-[#B57E5F] transition-all flex items-center justify-center gap-2 active:scale-95 shadow-md"
                >
                  <Icon name="tabler:shopping-bag" class="w-5 h-5" /> Agregar
                </button>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
