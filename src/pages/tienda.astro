---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Tienda de Rituales — RitoHouse',
};

// Estructura de productos (Aquí puedes agregar más fácilmente)
const productos = [
  {
    id: 'e1',
    categoria: 'esenciales',
    nombre: 'Box Inicio Sagrado',
    descripcion: 'Lo fundamental para tu primer ritual de limpieza.',
    precio: '850',
    detalles: ['Pieza de yeso base', 'Vela blanca', '3 Sahumerios'],
  },
  {
    id: 'ex1',
    categoria: 'expansion',
    nombre: 'Box Expansión Áurea',
    descripcion: 'Conexión profunda con elementos de la naturaleza.',
    precio: '1450',
    detalles: ['Set de 3 piezas', 'Botánica seca', 'Tarjetas de decreto'],
  },
  {
    id: 't1',
    categoria: 'trascendencia',
    nombre: 'Box Trascendencia Total',
    descripcion: 'La experiencia de alquimia definitiva y profesional.',
    precio: '2800',
    detalles: ['Piezas Premium Yeso/Cemento', 'Papelería especial', 'Kit Pro'],
  }
];
---

<Layout metadata={metadata}>
  <section class="bg-[#F2E8DF] min-h-screen py-20">
    <div class="max-w-7xl mx-auto px-4">
      
      <!-- TÍTULO Y FILTROS -->
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif font-bold text-[#3D2B1F] mb-4 uppercase">Catálogo de Rituales</h1>
        <p class="text-[#55463C] italic mb-8">Selecciona tu intención y concreta tu pedido por WhatsApp</p>
        
        <div class="flex flex-wrap justify-center gap-4 mb-12">
          <a href="#esenciales" class="px-6 py-2 rounded-full border border-[#B57E5F] text-[#3D2B1F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">ESENCIALES</a>
          <a href="#expansion" class="px-6 py-2 rounded-full border border-[#B57E5F] text-[#3D2B1F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">EXPANSIÓN</a>
          <a href="#trascendencia" class="px-6 py-2 rounded-full border border-[#B57E5F] text-[#3D2B1F] font-bold hover:bg-[#B57E5F] hover:text-white transition-all text-sm">TRASCENDENCIA</a>
        </div>
      </div>

      <!-- SECCIONES POR CATEGORÍA -->
      
      <!-- CATEGORÍA: ESENCIALES -->
      <div id="esenciales" class="mb-20 scroll-mt-24">
        <h2 class="text-3xl font-serif font-bold text-[#B57E5F] border-b border-[#B57E5F]/20 pb-2 mb-8 uppercase tracking-widest text-center md:text-left">1. Rituales Esenciales</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {productos.filter(p => p.categoria === 'esenciales').map(p => (
            <div class="bg-white/30 rounded-2xl border border-[#B57E5F]/10 p-6 flex flex-col group hover:shadow-xl transition-all">
              <div class="h-48 bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30">Foto Producto</div>
              <h3 class="text-xl font-bold text-[#3D2B1F] mb-2">{p.nombre}</h3>
              <p class="text-sm text-[#55463C] mb-4 flex-grow">{p.descripcion}</p>
              <div class="mb-6">
                <span class="text-2xl font-serif font-bold text-[#3D2B1F]">${p.precio}</span>
              </div>
              <a 
                href={`https://wa.me/tu_numero?text=Hola RitoHouse! Me interesa el ${p.nombre} de la línea Esencial.`}
                class="bg-[#3D2B1F] text-[#F2E8DF] text-center py-3 rounded-xl font-bold hover:bg-[#B57E5F] transition-colors flex items-center justify-center gap-2"
              >
                <Icon name="tabler:brand-whatsapp" class="w-5 h-5" /> Comprar por WP
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- CATEGORÍA: EXPANSIÓN -->
      <div id="expansion" class="mb-20 scroll-mt-24">
        <h2 class="text-3xl font-serif font-bold text-[#B57E5F] border-b border-[#B57E5F]/20 pb-2 mb-8 uppercase tracking-widest text-center md:text-left">2. Rituales Expansión</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {productos.filter(p => p.categoria === 'expansion').map(p => (
            <div class="bg-white/40 rounded-2xl border-2 border-[#B57E5F]/30 p-6 flex flex-col group shadow-md">
              <div class="h-48 bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30">Foto Producto</div>
              <h3 class="text-xl font-bold text-[#3D2B1F] mb-2">{p.nombre}</h3>
              <p class="text-sm text-[#55463C] mb-4 flex-grow">{p.descripcion}</p>
              <div class="mb-6">
                <span class="text-2xl font-serif font-bold text-[#3D2B1F]">${p.precio}</span>
              </div>
              <a 
                href={`https://wa.me/tu_numero?text=Hola RitoHouse! Quiero adquirir el ${p.nombre} de la línea Expansión.`}
                class="bg-[#B57E5F] text-white text-center py-3 rounded-xl font-bold hover:bg-[#3D2B1F] transition-colors flex items-center justify-center gap-2"
              >
                <Icon name="tabler:brand-whatsapp" class="w-5 h-5" /> Solicitar por WP
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- CATEGORÍA: TRASCENDENCIA -->
      <div id="trascendencia" class="mb-20 scroll-mt-24">
        <h2 class="text-3xl font-serif font-bold text-[#B57E5F] border-b border-[#B57E5F]/20 pb-2 mb-8 uppercase tracking-widest text-center md:text-left">3. Rituales Trascendencia</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {productos.filter(p => p.categoria === 'trascendencia').map(p => (
            <div class="bg-white/30 rounded-2xl border border-[#B57E5F]/10 p-6 flex flex-col group hover:shadow-xl transition-all">
              <div class="h-48 bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30">Foto Producto</div>
              <h3 class="text-xl font-bold text-[#3D2B1F] mb-2">{p.nombre}</h3>
              <p class="text-sm text-[#55463C] mb-4 flex-grow">{p.descripcion}</p>
              <div class="mb-6">
                <span class="text-2xl font-serif font-bold text-[#3D2B1F]">${p.precio}</span>
              </div>
              <a 
                href={`https://wa.me/tu_numero?text=Hola RitoHouse! Deseo el ${p.nombre} Premium de la línea Trascendencia.`}
                class="bg-[#3D2B1F] text-[#F2E8DF] text-center py-3 rounded-xl font-bold hover:bg-[#B57E5F] transition-colors flex items-center justify-center gap-2"
              >
                <Icon name="tabler:brand-whatsapp" class="w-5 h-5" /> Pedido Premium WP
              </a>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>
