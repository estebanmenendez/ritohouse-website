---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Tienda General — Accesorios RitoHouse',
};

// Ejemplo de productos individuales
const accesorios = [
  { nombre: 'Bandeja Ovalada', categoria: 'Yeso y Cemento', precio: '350' },
  { nombre: 'Vela Aromática Soja', categoria: 'Velas', precio: '420' },
  { nombre: 'Inciensos Naturales', categoria: 'Aromaterapia', precio: '280' },
  { nombre: 'Palo Santo Selecto', categoria: 'Aromaterapia', precio: '150' },
  { nombre: 'Jabón Artesanal', categoria: 'Bienestar', precio: '220' },
];
---

<Layout metadata={metadata}>
  <section class="bg-[#F2E8DF] min-h-screen py-20 text-[#3D2B1F]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif font-bold mb-4 uppercase">Tienda General</h1>
        <p class="italic text-[#55463C]">Accesorios individuales para complementar tu santuario personal</p>
      </div>

      <!-- Grid de Accesorios -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {accesorios.map((item) => (
          <div class="bg-white/30 p-4 rounded-2xl border border-[#B57E5F]/10 hover:shadow-lg transition-all flex flex-col text-center">
            <div class="aspect-square bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30">Foto</div>
            <p class="text-[10px] uppercase tracking-widest text-[#B57E5F] font-bold mb-1">{item.categoria}</p>
            <h3 class="font-bold mb-2 flex-grow">{item.nombre}</h3>
            <p class="font-serif font-bold mb-4">${item.precio}</p>
            <a 
              href={`https://wa.me/tu_numero?text=Hola! Me interesa comprar el accesorio: ${item.nombre}`}
              class="bg-[#3D2B1F] text-[#F2E8DF] py-2 rounded-lg text-sm font-bold hover:bg-[#B57E5F] transition-colors"
            >
              Comprar
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
