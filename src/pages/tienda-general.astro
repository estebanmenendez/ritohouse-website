---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Tienda General — Accesorios RitoHouse',
};

// Catálogo organizado por categorías para facilitar el filtrado
const accesorios = [
  // PIEZAS DE YESO Y CEMENTO
  { nombre: 'Bandeja Ovalada', categoria: 'yeso-y-cemento', etiqueta: 'Yeso y Cemento', precio: '350' },
  { nombre: 'Portavelas Cónico', categoria: 'yeso-y-cemento', etiqueta: 'Yeso y Cemento', precio: '280' },
  { nombre: 'Cuenco de Intención', categoria: 'yeso-y-cemento', etiqueta: 'Yeso y Cemento', precio: '450' },
  { nombre: 'Altar de Mano', categoria: 'yeso-y-cemento', etiqueta: 'Yeso y Cemento', precio: '520' },

  // VELAS Y LUZ
  { nombre: 'Vela Aromática Soja', categoria: 'velas', etiqueta: 'Velas', precio: '420' },
  { nombre: 'Vela de Alquimia Blanca', categoria: 'velas', etiqueta: 'Velas', precio: '180' },
  { nombre: 'Vela de Miel Pura', categoria: 'velas', etiqueta: 'Velas', precio: '250' },
  { nombre: 'Set Velas de Té (x4)', categoria: 'velas', etiqueta: 'Velas', precio: '320' },

  // SAHUMADO Y AROMATERAPIA
  { nombre: 'Inciensos Naturales', categoria: 'aromaterapia', etiqueta: 'Aromaterapia', precio: '280' },
  { nombre: 'Palo Santo Selecto', categoria: 'aromaterapia', etiqueta: 'Aromaterapia', precio: '150' },
  { nombre: 'Atado de Salvia Blanca', categoria: 'aromaterapia', etiqueta: 'Aromaterapia', precio: '480' },
  { nombre: 'Bombitas de Defumación', categoria: 'aromaterapia', etiqueta: 'Aromaterapia', precio: '190' },

  // BIENESTAR Y ELEMENTOS
  { nombre: 'Jabón Artesanal', categoria: 'bienestar', etiqueta: 'Bienestar', precio: '220' },
  { nombre: 'Sal de Baño Energética', categoria: 'bienestar', etiqueta: 'Bienestar', precio: '390' },
  { nombre: 'Cristal de Cuarzo', categoria: 'bienestar', etiqueta: 'Bienestar', precio: '450' },
  { nombre: 'Aceite Esencial Puro', categoria: 'bienestar', etiqueta: 'Bienestar', precio: '580' },
];

const categorias = [
  { id: 'yeso-y-cemento', nombre: 'YESO Y CEMENTO' },
  { id: 'velas', nombre: 'VELAS' },
  { id: 'aromaterapia', nombre: 'AROMATERAPIA' },
  { id: 'bienestar', nombre: 'BIENESTAR' },
];
---

<Layout metadata={metadata}>
  <section class="bg-[#F2E8DF] min-h-screen py-20 text-[#3D2B1F]">
    <div class="max-w-7xl mx-auto px-4">
      
      <!-- ENCABEZADO Y FILTROS -->
      <div class="text-center mb-16">
        <h1 class="text-5xl font-serif font-bold mb-4 uppercase tracking-tighter">Tienda General</h1>
        <p class="italic text-[#55463C] text-lg mb-8">Elementos individuales para crear tu propio espacio de calma</p>
        
        <div class="flex flex-wrap justify-center gap-4">
          {categorias.map(cat => (
            <a 
              href={`#${cat.id}`} 
              class="px-6 py-2 rounded-full border border-[#B57E5F] font-bold text-[#3D2B1F] hover:bg-[#B57E5F] hover:text-white transition-all text-sm uppercase"
            >
              {cat.nombre}
            </a>
          ))}
        </div>
      </div>

      <!-- SECCIONES POR CATEGORÍA -->
      {categorias.map((cat) => (
        <div id={cat.id} class="mb-20 scroll-mt-24">
          <h2 class="text-3xl font-serif font-bold text-[#B57E5F] border-b border-[#B57E5F]/20 pb-2 mb-10 uppercase tracking-widest text-center md:text-left">
            {cat.nombre}
          </h2>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {accesorios.filter(item => item.categoria === cat.id).map((item) => (
              <div class="bg-white/30 p-4 rounded-2xl border border-[#B57E5F]/10 hover:shadow-lg transition-all flex flex-col items-center text-center group">
                <div class="aspect-square w-full bg-[#EAE5DE] rounded-xl mb-4 flex items-center justify-center italic text-[#B57E5F]/30 overflow-hidden">
                  <span class="group-hover:scale-110 transition-transform duration-500 text-xs px-2">Foto {item.nombre}</span>
                </div>
                
                <p class="text-[10px] uppercase tracking-widest text-[#B57E5F] font-bold mb-1">{item.etiqueta}</p>
                <h3 class="font-bold mb-2 flex-grow text-md leading-tight text-[#3D2B1F]">{item.nombre}</h3>
                <p class="font-serif font-bold mb-4 text-lg text-[#3D2B1F]">${item.precio}</p>
                
                <button 
                  onclick={`agregarAlCarrito('${item.nombre}', '${item.precio}')`}
                  class="w-full bg-[#3D2B1F] text-[#F2E8DF] py-3 rounded-xl text-sm font-bold hover:bg-[#B57E5F] transition-all active:scale-95 flex items-center justify-center gap-2 shadow-md"
                >
                  <Icon name="tabler:plus" class="w-4 h-4" />
                  Agregar
                </button>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
